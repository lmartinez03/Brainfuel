{
  "expo": {
    "name": "Brainfuel",
    "slug": "brainfuel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "brainfuel",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brainfuel.app",
      "appleTeamId": "SZW9Q2A567",
      "infoPlist": {
        "NSCameraUsageDescription": "Not required",
        "LSApplicationQueriesSchemes": [
          "instagram",
          "tiktok",
          "snapchat",
          "barcelona",
          "pinterest",
          "tumblr",
          "youtube",
          "twitch",
          "nflx",
          "hulu",
          "disneyplus",
          "twitter",
          "fb",
          "reddit",
          "mastodon",
          "discord",
          "tg",
          "whatsapp",
          "spotify",
          "soundcloud",
          "roblox",
          "steam",
          "com.amazon.mobile.shopping",
          "ebay",
          "etsy",
          "shortcuts"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F1A"
      },
      "package": "com.brainfuel.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#0D0F1A",
          "imageWidth": 220
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "SZW9Q2A567",
          "appGroup": "group.com.brainfuel.app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
