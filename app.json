{
  "expo": {
    "name": "Brainfuel",
    "slug": "brainfuel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": ["brainfuel", "device-activity"],
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brainfuel.app",
      "appleTeamId": "SZW9Q2A567",
      "infoPlist": {
        "NSCameraUsageDescription": "Not required",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "instagram",
          "tiktok",
          "snapchat",
          "barcelona",
          "pinterest",
          "tumblr",
          "youtube",
          "twitch",
          "nflx",
          "hulu",
          "disneyplus",
          "twitter",
          "fb",
          "reddit",
          "mastodon",
          "discord",
          "tg",
          "whatsapp",
          "spotify",
          "soundcloud",
          "roblox",
          "steam",
          "com.amazon.mobile.shopping",
          "ebay",
          "etsy",
          "shortcuts"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Mascot.png",
        "backgroundColor": "#ffbf57"
      },
      "package": "com.brainfuel.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Mascot.png",
          "backgroundColor": "#ffbf57",
          "imageWidth": 220
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "SZW9Q2A567",
          "appGroup": "group.com.brainfuel.app"
        }
      ],
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.brainfuel.app.ShieldConfiguration",
                  "targetName": "ShieldConfiguration",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.brainfuel.app"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.brainfuel.app.ShieldAction",
                  "targetName": "ShieldAction",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.brainfuel.app"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.brainfuel.app.ActivityMonitorExtension",
                  "targetName": "ActivityMonitorExtension",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.brainfuel.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "eb6dd908-b913-4626-bf2d-701a42f863ff"
      }
    },
    "owner": "lucafmartinez"
  }
}
